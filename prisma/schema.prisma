// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}



model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  phone         String?
  role          String    @default("CUSTOMER")
  
  // Profile Customization
  bio           String?
  avatarUrl     String?
  portfolioUrls String?   // Comma-separated list of image URLs

  // Relations
  accounts      Account[]
  
  barbershopId  String?
  barbershop    Barbershop? @relation("StaffToShop", fields: [barbershopId], references: [id])
  
  appointmentsAsCustomer Appointment[] @relation("CustomerAppointments")
  appointmentsAsBarber   Appointment[] @relation("BarberAppointments")

  schedules     Schedule[]
  timeOffs      TimeOff[]

  clientNotes    ClientNote[] @relation("CustomerNotes")
  notesWritten   ClientNote[] @relation("BarberNotes")
  staffGoals     StaffGoal[]
  salesMade      Sale[]       @relation("BarberSales")
  purchases      Sale[]       @relation("CustomerPurchases")

  // Client Metrics
  loyaltyPoints  Int          @default(0)
  noShowCount    Int          @default(0)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Barbershop {
  id          String   @id @default(cuid())
  slug        String?  @unique @default(uuid())
  name        String
  address     String?
  phone       String?
  
  // Customization
  heroImageUrl  String?
  galleryUrls   String?   // Comma-separated list of image URLs
  
  // Relations
  staff       User[]   @relation("StaffToShop")
  services    Service[]
  appointments Appointment[]
  timeOffs    ShopTimeOff[]
  clientNotes ClientNote[]
  staffGoals  StaffGoal[]
  products    Product[]
  sales       Sale[]

  // Feature Flags (App Modules)
  isCrmEnabled          Boolean @default(true)
  isPosEnabled          Boolean @default(true)
  isGamificationEnabled Boolean @default(true)
  isMarketingEnabled    Boolean @default(false)
  isLoyaltyEnabled      Boolean @default(false)

  // Regional/Localization
  currency              String  @default("USD")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id           String     @id @default(cuid())
  name         String
  description  String?
  price        Float
  durationMins Int        // e.g. 30, 45, 60

  // Relations
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Appointment {
  id           String            @id @default(cuid())
  date         DateTime
  startTime    DateTime
  endTime      DateTime
  status       String     @default("PENDING")

  // Relations
  customerId   String
  customer     User       @relation("CustomerAppointments", fields: [customerId], references: [id])
  
  barberId     String
  barber       User       @relation("BarberAppointments", fields: [barberId], references: [id])
  
  serviceId    String
  service      Service    @relation(fields: [serviceId], references: [id])
  
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Schedule {
  id           String     @id @default(cuid())
  barberId     String
  barber       User       @relation(fields: [barberId], references: [id], onDelete: Cascade)
  
  dayOfWeek    Int        // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  startTime    String     // Format HH:mm (e.g., "09:00")
  endTime      String     // Format HH:mm (e.g., "18:00")
  isWorkingDay Boolean    @default(true) // If false, the barber does not work on this day

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([barberId, dayOfWeek])
}

model TimeOff {
  id           String     @id @default(cuid())
  barberId     String
  barber       User       @relation(fields: [barberId], references: [id], onDelete: Cascade)

  date         DateTime   // Specific date they have taken off
  reason       String?    // E.g., Vacation, Sick leave, Personal

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([barberId, date])
}

model ShopTimeOff {
  id           String     @id @default(cuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  date         DateTime   // Specific date the entire shop is closed
  reason       String?    // E.g., National holiday, Renovation

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([barbershopId, date])
}

model ClientNote {
  id           String     @id @default(cuid())
  content      String     @db.Text
  
  customerId   String
  customer     User       @relation("CustomerNotes", fields: [customerId], references: [id], onDelete: Cascade)
  
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  
  authorId     String?
  author       User?      @relation("BarberNotes", fields: [authorId], references: [id], onDelete: SetNull)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model StaffGoal {
  id           String     @id @default(cuid())
  
  barberId     String
  barber       User       @relation(fields: [barberId], references: [id], onDelete: Cascade)
  
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  
  month        Int        // 1-12
  year         Int        // e.g., 2024
  targetAmount Float      // The revenue goal for the month
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  @@unique([barberId, month, year])
}

model Product {
  id           String     @id @default(cuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  
  name         String
  description  String?
  price        Float
  stock        Int        @default(0)
  sku          String?
  imageUrl     String?

  saleItems    SaleItem[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Sale {
  id           String     @id @default(cuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  
  barberId     String
  barber       User       @relation("BarberSales", fields: [barberId], references: [id])
  
  customerId   String?
  customer     User?      @relation("CustomerPurchases", fields: [customerId], references: [id], onDelete: SetNull)

  items        SaleItem[]
  totalAmount  Float
  paymentMethod String     @default("CASH") // CASH, CARD, OTHER

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model SaleItem {
  id           String     @id @default(cuid())
  saleId       String
  sale         Sale       @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  
  quantity     Int
  priceAtSale  Float

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}
