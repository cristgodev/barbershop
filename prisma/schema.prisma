generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model User {
  id                     String        @id @default(cuid())
  name                   String?
  email                  String        @unique
  passwordHash           String?
  phone                  String?
  role                   String        @default("CUSTOMER")
  bio                    String?
  avatarUrl              String?
  portfolioUrls          String?
  barbershopId           String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  emailVerified          DateTime?
  image                  String?
  noShowCount            Int           @default(0)
  instagramUrl           String?
  tiktokUrl              String?
  showOnLanding          Boolean       @default(true)
  accounts               Account[]
  loyaltyBalances        CustomerLoyalty[]
  appointmentsAsBarber   Appointment[] @relation("BarberAppointments")
  appointmentsAsCustomer Appointment[] @relation("CustomerAppointments")
  notesWritten           ClientNote[]  @relation("BarberNotes")
  clientNotes            ClientNote[]  @relation("CustomerNotes")
  salesMade              Sale[]        @relation("BarberSales")
  purchases              Sale[]        @relation("CustomerPurchases")
  schedules              Schedule[]
  staffGoals             StaffGoal[]
  timeOffs               TimeOff[]
  barbershop             Barbershop?   @relation("StaffToShop", fields: [barbershopId], references: [id])
}

model Barbershop {
  id                    String        @id @default(cuid())
  slug                  String?       @unique @default(uuid())
  name                  String
  address               String?
  phone                 String?
  heroImageUrl          String?
  galleryUrls           String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  isCrmEnabled          Boolean       @default(false)
  isGamificationEnabled Boolean       @default(true)
  isLoyaltyEnabled      Boolean       @default(false)
  loyaltyRatio          Int           @default(5)
  isMarketingEnabled    Boolean       @default(false)
  isPosEnabled          Boolean       @default(false)
  isActive              Boolean       @default(true)
  currency              String        @default("USD")
  instagramUrl          String?
  tiktokUrl             String?
  appointments          Appointment[]
  clientNotes           ClientNote[]
  products              Product[]
  sales                 Sale[]
  services              Service[]
  timeOffs              ShopTimeOff[]
  staffGoals            StaffGoal[]
  campaigns             Campaign[]
  rewards               LoyaltyReward[]
  staff                 User[]        @relation("StaffToShop")
  loyaltyBalances        CustomerLoyalty[]
}

model LoyaltyReward {
  id           String     @id @default(cuid())
  barbershopId String
  name         String
  pointsCost   Int
  description  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
}

model Campaign {
  id           String     @id @default(cuid())
  barbershopId String
  message      String
  imageUrl     String?
  sentToCount  Int
  createdAt    DateTime   @default(now())
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
}

model Service {
  id           String        @id @default(cuid())
  name         String
  description  String?
  price        Float
  durationMins Int
  barbershopId String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  barbershop   Barbershop    @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
}

model Appointment {
  id           String     @id @default(cuid())
  date         DateTime
  startTime    DateTime
  endTime      DateTime
  status       String     @default("PENDING")
  customerId   String
  barberId     String
  serviceId    String
  barbershopId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  barber       User       @relation("BarberAppointments", fields: [barberId], references: [id])
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])
  customer     User       @relation("CustomerAppointments", fields: [customerId], references: [id])
  service      Service    @relation(fields: [serviceId], references: [id])
}

model Schedule {
  id           String   @id @default(cuid())
  barberId     String
  dayOfWeek    Int
  startTime    String
  endTime      String
  isWorkingDay Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  barber       User     @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek])
}

model TimeOff {
  id        String   @id @default(cuid())
  barberId  String
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  barber    User     @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, date])
}

model ShopTimeOff {
  id           String     @id @default(cuid())
  barbershopId String
  date         DateTime
  reason       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@unique([barbershopId, date])
}

model ClientNote {
  id           String     @id @default(cuid())
  content      String
  customerId   String
  barbershopId String
  authorId     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  author       User?      @relation("BarberNotes", fields: [authorId], references: [id])
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  customer     User       @relation("CustomerNotes", fields: [customerId], references: [id], onDelete: Cascade)
}

model StaffGoal {
  id           String     @id @default(cuid())
  barberId     String
  barbershopId String
  month        Int
  year         Int
  targetAmount Float
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  barber       User       @relation(fields: [barberId], references: [id], onDelete: Cascade)
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@unique([barberId, month, year])
}

model Product {
  id           String     @id @default(cuid())
  barbershopId String
  name         String
  description  String?
  price        Float
  stock        Int        @default(0)
  sku          String?
  imageUrl     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  saleItems    SaleItem[]
}

model Sale {
  id            String     @id @default(cuid())
  barbershopId  String
  barberId      String
  customerId    String?
  totalAmount   Float
  paymentMethod String     @default("CASH")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  barber        User       @relation("BarberSales", fields: [barberId], references: [id])
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  customer      User?      @relation("CustomerPurchases", fields: [customerId], references: [id])
  items         SaleItem[]
}

model SaleItem {
  id          String   @id @default(cuid())
  saleId      String
  productId   String
  quantity    Int
  priceAtSale Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id])
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model CustomerLoyalty {
  id           String     @id @default(cuid())
  userId       String
  barbershopId String
  points       Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@unique([userId, barbershopId])
}
